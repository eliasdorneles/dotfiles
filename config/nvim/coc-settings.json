{
  "coc.preferences.formatOnSave": false,
  "inlayHint.display": false,
  "python.formatting.provider": "ruff",
  "pyright.organizeimports.provider": "isort",
  "python.sortImports.path": "~/.local/bin/isort",
  "coc.preferences.jumpCommand": "tab drop",
  "outline.sortBy": "position",
  "outline.expandLevel": 0,
  "outline.autoWidth": true,
  "zig.enabled": true,
  "zig.path": "zls",
  "zig.debugLog": false,
  "clangd.fallbackFlags": [
    "-std=c++23",
  ],
  "markdownlint.config": {
    "default": true,
    "line_length": false,
    "blanks-around-lists": false,
    "blanks-around-headings": false
  },
  "workspace.ignoredFolders": [
      "$HOME",
      "$HOME/.cargo/**",
      "$HOME/.rustup/**"
  ],
  "Lua.workspace.checkThirdParty": "Apply",
  "languageserver": {
    "turtle": {
      "command": "turtle_langserver",
      "filetypes": ["ttl", "turtle"]
    },
    "odin": {
      "command": "ols",
      "filetypes": ["odin"],
      "rootPatterns": ["ols.json"]
    }
  }
}
